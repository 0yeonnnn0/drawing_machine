{
  "name": "doodleshare",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:web\" \"npm run dev:server\"",
    "dev:web": "npm -w apps/web run dev",
    "dev:server": "npm -w apps/server run dev",
    "build": "npm -w apps/web run build",
    "lint": "npm -w apps/web run lint"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "typescript": "~5.8.2"
  }
}
